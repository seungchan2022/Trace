#!/bin/sh
set -eu

branch="$(git symbolic-ref --quiet --short HEAD || true)"

if [ "${ALLOW_MAIN_MERGE:-}" = "1" ]; then
  exit 0
fi

if [ "$branch" = "main" ]; then
  echo "Merge blocked: main 통합은 명시적 수동 merge만 허용합니다." >&2
  echo "승인 시:  ALLOW_MAIN_MERGE=1 git merge --ff-only <branch>" >&2
  exit 1
fi
