{
  "permissions": {
    "deny": [
      "Bash(git push*)",
      "Bash(*git push*)",
      "Bash(*ALLOW_PUSH*)",
      "Bash(git add -A*)",
      "Bash(git add .)",
      "Bash(git add . *)",
      "Bash(*--no-verify*)",
      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Edit(.env*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "BACKUP_DIR=\"${CLAUDE_BACKUP_DIR:-$HOME/.claude/backups}\"; mkdir -p \"$BACKUP_DIR\" && cp \"$CLAUDE_TRANSCRIPT_PATH\" \"$BACKUP_DIR/trace-$(date +%s).jsonl\" 2>/dev/null; echo '💾 대화 백업 완료'"
          }
        ]
      }
    ]
  }
}
